using System;

namespace Task20_ReverseOrder
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Задание 20. Вывод в обратном порядке";
            
            Console.Write("Введите длину массива n: ");
            int n = int.Parse(Console.ReadLine());
            
            int[] array = new int[n];
            Random rnd = new Random();
            
            Console.WriteLine("\nИсходный массив:");
            for (int i = 0; i < n; i++)
            {
                array[i] = rnd.Next(1, 100);
                Console.Write(array[i] + " ");
            }
            
            Console.WriteLine("\n\nМассив в обратном порядке:");
            for (int i = n - 1; i >= 0; i--)
            {
                Console.Write(array[i] + " ");
            }
            Console.WriteLine();
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
