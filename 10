using System;

namespace ArrayHasNegative
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 6. Проверка наличия отрицательного элемента";
            
            Console.Write("Введите длину массива n: ");
            int n = int.Parse(Console.ReadLine());
            
            int[] array = new int[n];
            
            Console.WriteLine($"\nВведите {n} целых чисел:");
            for (int i = 0; i < n; i++)
            {
                Console.Write($"Элемент {i}: ");
                array[i] = int.Parse(Console.ReadLine());
            }
            
            Console.WriteLine("\nМассив:");
            for (int i = 0; i < n; i++)
            {
                Console.Write(array[i] + " ");
            }
            
            bool hasNegative = false;
            for (int i = 0; i < n; i++)
            {
                if (array[i] < 0)
                {
                    hasNegative = true;
                    break;
                }
            }
            
            Console.WriteLine($"\n\nЕсть хотя бы один отрицательный элемент: {hasNegative}");
            
            if (hasNegative)
            {
                Console.Write("Отрицательные элементы: ");
                for (int i = 0; i < n; i++)
                {
                    if (array[i] < 0)
                        Console.Write(array[i] + " ");
                }
                Console.WriteLine();
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
